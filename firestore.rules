rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /appointments/{appointmentId} {
      allow read: if true;
      allow create: if true; 
      allow update, delete: if isAdmin();
    }
    
    match /clients/{clientId} {
      allow read, create: if true;
      allow update: if true; // Allows clients to update their own stats when booking
      allow delete: if isAdmin();
    }
    
    match /business_analytics/{analyticsId} {
      allow read, write: if isAdmin(); // Analytics must be private
    }
    
    match /admins/{adminId} {
      allow read: if request.auth != null && (request.auth.uid == adminId || isAdmin());
      allow write: if isAdmin();
    }
    
    match /machines/{machineId} {
      allow read, write: if isAdmin();
    }
    
    match /prices/{priceId} {
      allow read, write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /blocked_slots/{slotId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
