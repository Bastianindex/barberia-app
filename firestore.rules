rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funciones de Ayuda
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- REGLAS POR COLECCIÓN ---

    // Servicios: Público para lectura, Admin para escritura
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Citas: 
    // - Propietario puede leer sus propias citas y crear nuevas.
    // - Admin tiene control total.
    match /appointments/{appointmentId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.clientId == request.auth.uid && request.resource.data.status == 'cancelled');
      allow delete: if isAdmin();
    }
    
    // Clientes:
    // - Solo el dueño puede leer/editar su perfil.
    match /clients/{clientId} {
      allow read, update: if isAdmin() || isOwner(clientId);
      allow create: if isAuthenticated(); // Permite registro inicial
      allow delete: if isAdmin();
    }
    
    // Analítica: Estrictamente privado para Admins
    match /business_analytics/{analyticsId} {
      allow read, write: if isAdmin();
    }
    
    // Admins: Solo el propio admin o un super-admin puede leer
    match /admins/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow write: if isAdmin();
    }
    
    // Configuración y Precios
    match /prices/{priceId} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{settingId} { allow read: if true; allow write: if isAdmin(); }
    match /blocked_slots/{slotId} { allow read: if true; allow write: if isAdmin(); }

    // Denegar todo lo demás por defecto
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}

